// Focus: operations: arithmetic, comparison, logical

i32 main() {
    i32 a = 8 + 5 * 2 - 3
    i32 b = (8 + 5) * (2 - 3)

    i32 res1
    res1 = -a
    res1 = a + b
    res1 = a - b
    res1 = a * b
    res1 = a / b
    res1 = a % b
    res1 += b
    res1 -= b
    res1 *= b
    res1 /= b
    res1 %= b

    bool res2
    res2 = a == b
    res2 = a != b
    res2 = a < b
    res2 = a <= b
    res2 = a > b
    res2 = a >= b

    bool res3
    res3 = (a > b) and (b > 0)
    res3 = (a > b) or (b > 0)
    res3 = not (a > b)

    i32 res4
    res4 = a & b
    res4 = a | b
    res4 = a ^ b
    res4 = ~a
    res4 = a << 2
    res4 = a >> 2
    res4 &= b
    res4 |= b
    res4 ^= b
    res4 <<= 2
    res4 >>= 2

    return 0
}
