// Focus: operations: arithmetic, comparison, logical

i32 main() {
    i32 a = 8 + 5 * 2 - 3
    i32 b = (8 + 5) * (2 - 3)

    i32 res1
    res1 = a + b
    res1 = a - b
    res1 = a * b
    res1 = a / b
    res1 = a % b

    bool res2
    res2 = a == b
    res2 = a != b
    res2 = a < b
    res2 = a <= b
    res2 = a > b
    res2 = a >= b

    bool res3
    res3 = (a > b) and (b > 0)
    res3 = (a > b) or (b > 0)
    res3 = not (a > b)

    return 0
}
