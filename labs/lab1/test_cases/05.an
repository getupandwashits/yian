// Focus: control flow: loop, for, while, if, match, break, continue

enum Grade {
    A
    B
    C
    F
}

i32 score(Grade g) {
    match g {
        A { return 4 }
        B { return 3 }
        C { return 2 }
        F { return 0 }
    }
}

i32 main() {
    i32 n = 0
    i32 sum_odd = 0

    loop {
        if n >= 10 {
            break
        } else {
            n += 1
        }
        if n % 2 == 0 {
            continue
        }
        sum_odd += n
    }

    i32 k = 1
    i32 sum_all = 0
    while k <= 5 {
        sum_all += k
        k += 1
    }

    i32 sum_for = 0
    for i32 i = 1; i <= 5; i += 1 {
        sum_for += i
    }

    Grade g = Grade.B
    i32 s = score(g)

    return 0
}
