// Focus: operations: arithmetic, comparison, logical

i32 main() {
    let a: i32 = 8 + 5 * 2 - 3;
    let b: i32 = (8 + 5) * (2 - 3);

    let res1: i32;
    res1 = -a;
    res1 = a + b;
    res1 = a - b;
    res1 = a * b;
    res1 = a / b;
    res1 = a % b;
    res1 += b;
    res1 -= b;
    res1 *= b;
    res1 /= b;
    res1 %= b;

    let res2: bool;
    res2 = a == b;
    res2 = a != b;
    res2 = a < b;
    res2 = a <= b;
    res2 = a > b;
    res2 = a >= b;

    let res3: bool;
    res3 = (a > b) and (b > 0);
    res3 = (a > b) or (b > 0);
    res3 = not (a > b);

    let res4: i32;
    res4 = a & b;
    res4 = a | b;
    res4 = a ^ b;
    res4 = ~a;
    res4 = a << 2;
    res4 = a >> 2;
    res4 &= b;
    res4 |= b;
    res4 ^= b;
    res4 <<= 2;
    res4 >>= 2;

    // ===== precedence / associativity checks =====
    a = b = 0;
    let p1: i32 = 2 + 3 * 4;
    let p2: i32 = (2 + 3) * 4;
    let p3: i32 = 20 / 5 * 2;
    let p4: i32 = 20 - 5 - 3;
    let p5: bool = 1 + 2 * 3 == 7;
    let p6: bool = not (1 + 2 * 3 == 8);
    let p7: bool = 1 < 2 and 3 < 4 or false;
    let p8: i32 = 1 + 2 << 1;
    let p9: i32 = 1 + (2 << 1);
    let p10: i32 = 8 >> 1 + 1;
    let p11: bool = 1 == 1 and 0 == 1 or true;
    let p12: i32;
    p12 = 9;
    p12 += 3 * 2;

    return 0;
}
