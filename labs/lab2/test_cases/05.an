// Focus: control flow: loop, for, while, if, match, break, continue

enum Grade {
    A
    B
    C
    F
}

i32 score(Grade g) {
    match g {
        A { return 4; }
        B { return 3; }
        C { return 2; }
        F { return 0; }
    }
}

i32 main() {
    let n: i32 = 0;
    let sum_odd: i32 = 0;

    loop {
        if n >= 10 {
            break;
        } else {
            n += 1;
        }
        if n % 2 == 0 {
            continue;
        }
        sum_odd += n;
    }

    let k: i32 = 1;
    let sum_all: i32 = 0;
    while k <= 5 {
        sum_all += k;
        k += 1;
    }

    let sum_for: i32 = 0;
    for let i: i32 = 1; i <= 5; i += 1 {
        sum_for += i;
    }

    let g: Grade = Grade.B;
    let s: i32 = score(g);

    return 0;
}
