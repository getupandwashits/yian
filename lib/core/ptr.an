impl<T> RawPtr<T> {
    bool __is_stack() {
        return (self.key_or_len & (u64(1) << 63)) == 0
    }
    bool __is_heap() {
        return (self.key_or_len & (u64(1) << 63)) != 0
    }
    __check_ptr_type_match(RawPtr<T> rhs) {
        if ((self.key_or_len ^ rhs.key_or_len) & (u64(1) << 63)) != 0 {
            panic("Stack ptr vs. Heap ptr")
        }
    }
    bool __key_lock_match() {
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        return mb.lock == self.key_or_len
    }
    // 需要改为private
    pub T* get_raw() {
        T* res
        if self.__is_stack() {
            res = bitcast<T*>(self.address)
        } else {
            res = bitcast<T*>(self.address + sizeof(MemoryBlock))
        }
        return res
    }

    // 构造指针
    pub static RawPtr<T> new_object() {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[u64(sizeof(MemoryBlock) + sizeof(T))]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        // 然后构造指针
        return RawPtr<T>(raw_buffer, key_lock)
    }

    // 需要改成内置函数
    pub static RawPtr<T> from_full(FullPtr<T> full_ptr) {
        assert full_ptr.len() == 1: "FullPtr length must be 1"
        return RawPtr<T>(full_ptr.address, full_ptr.key_or_len)
    }

    pub static RawPtr<T> from_slice(Slice<T> slice_ptr) {
        assert slice_ptr.len() == 1: "Slice length must be 1"
        return RawPtr<T>(slice_ptr.address, slice_ptr.key_or_len)
    }

    pub FullPtr<T> to_full() {
        return FullPtr<T>.from_raw(self)
    }

    pub Slice<T> to_slice() {
        return Slice<T>.from_raw(self)
    }

    static RawPtr<T> to_heap(T* init_value_addr) {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        T* data_ptr = bitcast<T*>(byte_offset(base, i64(sizeof(MemoryBlock))))
        memcpy(data_ptr, init_value_addr, sizeof(T))
        // 然后构造指针
        return RawPtr<T>(raw_buffer, key_lock)
    }
    static RawPtr<T> heap_address(T* raw_ptr) {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        T* data_ptr = bitcast<T*>(byte_offset(base, i64(sizeof(MemoryBlock))))
        memcpy(raw_ptr, data_ptr, sizeof(T))
        // 然后构造指针
        return RawPtr<T>(raw_buffer, key_lock)
    }

    // 对栈变量取地址
    static RawPtr<T> address(T* raw_ptr) {
        return RawPtr<T>(raw_ptr, sizeof(T))
    }

    bool is_valid() {
        if self.__is_stack() {
            return true
        }
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        return self.key_or_len == mb.lock
    }
    
    copy_to(RawPtr<T> other) {
        T* raw_ptr
        T* other_raw_ptr
        if self.__is_stack() {
            raw_ptr = bitcast<T*>(self.address)
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            raw_ptr = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock))))
        }
        if other.__is_stack() {
            other_raw_ptr = bitcast<T*>(other.address)
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(other.address)
            other_raw_ptr = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock))))
        }
        *other_raw_ptr = *raw_ptr
    }

    pub delete() {
        assert self.__is_heap(): "can only delete heap ptr"
        assert self.__key_lock_match(): "Heap ptr delete key mismatch"
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        mb.lock = 0
        del mb
    }
}

// 解引用
impl<T> Deref<T> for RawPtr<T> {
    T* deref() {
        if self.__is_stack() {
            T* buff = bitcast<T*>(self.address)
            return buff
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            // 检查 key 与 lock 匹配
            assert self.__key_lock_match(): "Heap ptr deref key mismatch"
            T* buff = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock))))
            return buff
        }
    }
}

