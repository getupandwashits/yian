// 索引
impl<T> Index<u64, T> for FullPtr<T> {
    T* index(u64 index) {
        if self.__is_stack() {
            assert index * sizeof(T) + self.offset < self.key_or_len: "Stack ptr index out of range"
            T* buff = bitcast<T*>(byte_offset(self.address, i64(self.offset)))
            return buff + index
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            // 检查 key 与 lock 匹配
            assert self.__key_lock_match(): "Heap ptr index key mismatch"
            // 检查越界
            assert index * sizeof(T) + self.offset < mb.size: "Heap ptr index out of range"
            T* buff = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock) + self.offset)))
            return buff + index
        }
    }
}

// 解引用
impl<T> Deref<T> for FullPtr<T> {
    T* deref() {
        if self.__is_stack() {
            assert self.offset < self.key_or_len: "Stack ptr deref out of range"
            T* buff = bitcast<T*>(byte_offset(self.address, i64(self.offset)))
            return buff
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            // 检查 key 与 lock 匹配
            assert self.__key_lock_match(): "Heap ptr deref key mismatch"
            // 检查越界
            assert self.offset < mb.size: "Heap ptr deref out of range"
            T* buff = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock) + self.offset)))
            return buff
        }
    }
}

