impl<T> Slice<T> {
    bool __is_stack() {
        return (self.key_or_len & (u64(1) << 63)) == 0
    }
    bool __is_heap() {
        return (self.key_or_len & (u64(1) << 63)) != 0
    }
    __check_ptr_type_match(Slice<T> rhs) {
        if ((self.key_or_len ^ rhs.key_or_len) & (u64(1) << 63)) != 0 {
            panic("Stack ptr vs. Heap ptr")
        }
    }
    bool __key_lock_match() {
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        return mb.lock == self.key_or_len
    }
    // 需要改为private
    pub T* get_raw() {
        T* res
        if self.__is_stack() {
            res = bitcast<T*>(self.address)
        } else {
            res = bitcast<T*>(self.address + sizeof(MemoryBlock))
        }
        return res
    }

    pub u64 get_len() {
        if self.__is_stack() {
            return self.key_or_len / sizeof(T)
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            return mb.size / sizeof(T)
        }
    }
    // 构造指针
    pub static Slice<T> new_object() {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        // 然后构造指针
        return Slice<T>(raw_buffer, key_lock)
    }
    pub static Slice<T> new_array(u64 len) {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + len * sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = len * sizeof(T)
        // 然后构造指针
        return Slice<T>(raw_buffer, key_lock)
    }

    // 需要改成内置函数
    pub static from_raw(RawPtr<T> raw_ptr) {
        return Slice<T>(raw_ptr.address, raw_ptr.key_or_len)
    }

    pub static from_full(FullPtr<T> full_ptr) {
        return Slice<T>(full_ptr.address, full_ptr.key_or_len)
    }

    pub to_raw() {
        return RawPtr<T>.from_slice(self)
    }

    pub to_full() {
        return FullPtr<T>.from_slice(self)
    }

    static Slice<T> to_heap(T* init_value_addr) {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        T* data_ptr = bitcast<T*>(base + sizeof(MemoryBlock))
        memcpy(data_ptr, init_value_addr, sizeof(T))
        // 然后构造指针
        return Slice<T>(raw_buffer, key_lock)
    }
    static Slice<T> heap_address(T* raw_ptr) {
        // 生成 key 和 lock
        u64 key_lock = random()
        // 构造 MemoryBlock + Buffer
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + sizeof(T)]
        MemoryBlock* base = bitcast<MemoryBlock*>(raw_buffer)
        base.lock = key_lock
        base.size = sizeof(T)
        T* data_ptr = bitcast<T*>(base + sizeof(MemoryBlock))
        memcpy(raw_ptr, data_ptr, sizeof(T))
        // 然后构造指针
        return Slice<T>(raw_buffer, key_lock)
    }

    // 对栈变量取地址
    static Slice<T> address(T* raw_ptr) {
        return Slice<T>(raw_ptr, sizeof(T))
    }
    // 从数组退化成指针
    static Slice<T> from_array(T* array, u64 len) {
        return Slice<T>(array, len * sizeof(T))
    }

    bool is_valid() {
        if self.__is_stack() {
            return true
        }
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        return self.key_or_len == mb.lock
    }
    pub realloc(u64 len) {
        assert not self.__is_stack(): "cannot realloc stack pointer"
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        // 检查 key 和 lock 匹配
        assert self.__key_lock_match(): "Heap ptr delete key mismatch"
        // 重新生成 key 和 lock
        u64 new_key_lock = random()
        // 重新生成 MemoryBlock
        i8* raw_buffer = dyn i8[sizeof(MemoryBlock) + len * sizeof(T)]
        MemoryBlock* new_base = bitcast<MemoryBlock*>(raw_buffer)
        new_base.lock = new_key_lock
        new_base.size = len * sizeof(T)
        // 复制数据
        u64 copy_size
        if mb.size < len * sizeof(T) {
            copy_size = mb.size
        } else {
            copy_size = len * sizeof(T)
        }
        copy_size /= sizeof(T)
        T* old_data = bitcast<T*>(byte_offset(mb, sizeof(MemoryBlock)))
        T* new_data = bitcast<T*>(byte_offset(new_base, sizeof(MemoryBlock)))
        for u64 i = 0; i < copy_size; i += 1 {
            new_data[i] = old_data[i]
        }
        // 释放原内存
        del mb
        // 修改自己
        self.address = raw_buffer
        self.key_or_len = new_key_lock
    }
    copy_to(Slice<T> other, u64 len) {
        u64 valid_len
        u64 other_valid_len
        T* raw_ptr
        T* other_raw_ptr
        if self.__is_stack() {
            valid_len = self.key_or_len / sizeof(T)
            raw_ptr = bitcast<T*>(self.address)
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            valid_len = mb.size / sizeof(T)
            raw_ptr = bitcast<T*>(byte_offset(mb, sizeof(MemoryBlock)))
        }
        if other.__is_stack() {
            valid_len = other.key_or_len / sizeof(T)
            raw_ptr = bitcast<T*>(other.address)
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(other.address)
            valid_len = mb.size / sizeof(T)
            raw_ptr = bitcast<T*>(byte_offset(mb, sizeof(MemoryBlock)))
        }
        assert valid_len >= len: "ptr does not have enough elements to copy"
        assert other_valid_len >= len: "ptr does not have enough elements to copy"
        for u64 i = 0; i < len; i += 1 {
            other_raw_ptr[i] = raw_ptr[i]
        }
    }

    pub delete() {
        assert self.__is_heap(): "can only delete heap ptr"
        assert self.__key_lock_match(): "Heap ptr delete key mismatch"
        MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
        mb.lock = 0
        del mb
    }
}

// 索引
impl<T> Index<u64, T> for Slice<T> {
    T* index(u64 index) {
        if self.__is_stack() {
            assert index * sizeof(T) < self.key_or_len: "Stack ptr index out of range"
            T* buff = bitcast<T*>(self.address)
            return buff + index
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            // 检查 key 与 lock 匹配
            assert self.__key_lock_match(): "Heap ptr index key mismatch"
            // 检查越界
            assert index * sizeof(T) < mb.size: "Heap ptr index out of range"
            T* buff = bitcast<T*>(byte_offset(mb, sizeof(MemoryBlock)))
            return buff + index
        }
    }
}

// 解引用
impl<T> Deref<T> for Slice<T> {
    T* deref() {
        if self.__is_stack() {
            // stack slice: address points directly to data
            T* buff = bitcast<T*>(self.address)
            return buff
        } else {
            MemoryBlock* mb = bitcast<MemoryBlock*>(self.address)
            // 检查 key 与 lock 匹配
            assert self.__key_lock_match(): "Heap ptr deref key mismatch"
            // heap slice: data starts right after MemoryBlock header
            T* buff = bitcast<T*>(byte_offset(mb, i64(sizeof(MemoryBlock))))
            return buff
        }
    }
}

